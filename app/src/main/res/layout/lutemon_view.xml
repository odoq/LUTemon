<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="125dp"
    android:layout_marginTop="5dp"
    android:background="#E2582D"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@android:drawable/alert_dark_frame" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtLutName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nimi"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/txtLutAttack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hyökkäys" />

        <TextView
            android:id="@+id/txtLutDefence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Puolustus" />

        <TextView
            android:id="@+id/txtLutHealth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Elämä" />

        <TextView
            android:id="@+id/txtLutExp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kokemus" />
    </LinearLayout>
</androidx.appcompat.widget.LinearLayoutCompat>